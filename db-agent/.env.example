# DB_AGENT Service Environment Variables
# Subset of root .env.example relevant to this service

# Claude terminal
ANTHROPIC_API_KEY=sk-ant-...

ENVIRONMENT=development
LOG_LEVEL=INFO

# This service
DB_AGENT_PORT=8003

# Internal token (required for all internal calls)
INTERNAL_SERVICE_TOKEN=change-me-internal-token

# Databases
LEGACY_DB_URL=postgresql://user:password@host:5432/legacy_db
LEGACY_DB_POOL_SIZE=10
DWH_URL=postgresql://user:password@host:5432/dwh
DWH_POOL_SIZE=5
LOGGING_DB_URL=postgresql://user:password@host:5432/logging_db

# Vector DB — Oracle 23ai (schema: mlsdev)
VECTOR_DB_HOST=host
VECTOR_DB_PORT=1528
VECTOR_DB_SERVICE=your_pdb.your_domain.oraclevcn.com
VECTOR_DB_USER=mlsdev
VECTOR_DB_PASSWORD=change-me
VECTOR_DB_POOL_MIN=2
VECTOR_DB_POOL_SIZE=5
